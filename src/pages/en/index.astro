---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/sections/Hero.astro";
import About from "@/components/sections/About.astro";
import Experience from "@/components/sections/Experience.astro";
import Education from "@/components/sections/Education.astro";
import Projects from "@/components/sections/Projects.astro";
import Skills from "@/components/sections/Skills.astro";
import KeyboardManager from "@/components/KeyboardManager.astro";

import cv from "@cv-en";
import { translations } from "@/i18n/utils";

const t = translations.en;
const { basics, work, education, skills, projects } = cv;
const { name, label } = basics;
---

<Layout title={`${name}'s resume | ${label}`} lang="en">
  <main>
    <nav class="language-selector no-print">
      <a href="/resume-es/">ES</a>
      <span>|</span>
      <a href="/resume-es/en/" class="active">EN</a>
    </nav>

    <Hero
      basics={basics}
      emailTitle={t.emailTitle(name, basics.email)}
      visitProfileTitle={(network: string) => t.visitProfile(name, network)}
    />
    <About title={t.aboutTitle} summary={basics.summary} />
    <Experience title={t.experienceTitle} work={work} presentLabel={t.present} />
    <Education title={t.educationTitle} education={education} presentLabel={t.present} />
    <Skills title={t.skillsTitle} skills={skills} />
    <Projects title={t.projectsTitle} projects={projects} visitProjectTitle={t.visitProject} />
  </main>

  <KeyboardManager
    profiles={basics.profiles}
    pressKey={t.pressKey}
    toOpenPanel={t.toOpenPanel}
    placeholder={t.placeholder}
    printResume={t.printResume}
    actionsLabel={t.actions}
    socialLabel={t.social}
    visitProfilePrefix="Visit"
  />
</Layout>

<style>
  main {
    padding: 4rem;
    margin: auto;
    width: 100%;
  }

  .language-selector {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    font-family: Menlo, Monaco, Lucida Console, monospace;
    margin-bottom: 2rem;
    max-width: 1000px;
    margin-inline: auto;
  }

  .language-selector a {
    color: #666;
    text-decoration: none;
    padding: 4px 8px;
    border-radius: 4px;
    transition: all 0.2s ease;
  }

  .language-selector a:hover {
    background: #eee;
    color: #111;
  }

  .language-selector a.active {
    font-weight: bold;
    color: #111;
    border: 1px solid #111;
  }

  .language-selector span {
    color: #ccc;
  }
</style>
