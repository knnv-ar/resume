---
import Section from "../Section.astro";

export interface Props {
  title: string;
  work: any[];
  presentLabel?: string;
}

const { title, work, presentLabel = "Present" } = Astro.props;
---

<Section title={title}>
  <ul>
    {
      work.map(
        ({ name, startDate, endDate, position, summary, url, highlights }) => {
          const startYear = new Date(startDate).getFullYear();
          const endYear =
            endDate != null ? new Date(endDate).getFullYear() : presentLabel;
          const years = `${startYear} - ${endYear}`;
          return (
            <li>
              <article>
                <header>
                  <div>
                    <h3>
                      {url ? (
                        <a href={url} target="_blank" rel="noopener noreferrer" class="company-link">
                          {name}
                        </a>
                      ) : (
                        name
                      )}
                    </h3>
                    <h4>{position}</h4>
                  </div>
                  <time>{years}</time>
                </header>
                <footer>
                  <p>{summary}</p>
                  {highlights && highlights.length > 0 && (
                    <ul class="highlights-list">
                      {highlights.map((highlight: string) => (
                        <li>{highlight}</li>
                      ))}
                    </ul>
                  )}
                </footer>
              </article>
            </li>
          );
        }
      )
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 500;
    color: var(--text-strong);
  }

  .company-link {
    color: var(--text-strong);
    transition: color 0.2s ease;
  }

  .company-link:hover {
    color: var(--accent-color);
    text-decoration: underline;
  }

  article h4 {
    font-weight: 400;
    font-variant-caps: all-small-caps;
    color: var(--text-color);
    letter-spacing: 0.2rem;
    margin-top: 4px;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: first baseline;
    margin-bottom: 12px;
  }

  time {
    color: var(--text-muted);
    font-size: 0.85rem;
    letter-spacing: -0.05rem;
  }

  .highlights-list {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    gap: 6px;
    margin-top: 10px;
  }

  .highlights-list li {
    border-radius: 4px;
    background: var(--badge-bg);
    color: var(--badge-color);
    font-size: 0.7rem;
    font-weight: 500;
    padding: 0.15rem 0.4rem;
  }
</style>
