---
import Section from "../Section.astro";

export interface Props {
  title: string;
  education: any[];
  presentLabel?: string;
}

const { title, education, presentLabel = "Present" } = Astro.props;
---

<Section title={title}>
  <ul>
    {
      education.map(
        ({ institution, area, studyType, startDate, endDate, url }) => {
          const startYear = new Date(startDate).getFullYear();
          const endYear =
            endDate != null ? new Date(endDate).getFullYear() : presentLabel;
          const years = `${startYear} - ${endYear}`;
          return (
            <li>
              <article>
                <header>
                  <div>
                    <h3>
                      {url ? (
                        <a href={url} target="_blank" rel="noopener noreferrer" class="institution-link">
                          {institution}
                        </a>
                      ) : (
                        institution
                      )}
                    </h3>
                    <h4>{area}</h4>
                  </div>
                  <time>{years}</time>
                </header>
                <footer>
                  <p>{studyType}</p>
                </footer>
              </article>
            </li>
          );
        }
      )
    }
  </ul>
</Section>

<style>
  ul {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  article h3 {
    font-weight: 500;
    color: var(--text-strong);
  }

  .institution-link {
    color: var(--text-strong);
    transition: color 0.2s ease;
  }

  .institution-link:hover {
    color: var(--accent-color);
    text-decoration: underline;
  }

  article h4 {
    font-weight: 400;
    font-variant-caps: all-small-caps;
    color: var(--text-color);
    letter-spacing: 0.2rem;
    margin-top: 4px;
  }

  header {
    display: flex;
    justify-content: space-between;
    align-items: first baseline;
    margin-bottom: 12px;
  }

  time {
    color: var(--text-muted);
    font-size: 0.85rem;
    letter-spacing: -0.05rem;
  }
</style>
