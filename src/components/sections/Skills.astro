---
import Section from "../Section.astro";

export interface Props {
  title: string;
  skills: any[];
}

const { title, skills } = Astro.props;
---

<Section title={title}>
  <ul>
    {
      skills.map(
        ({ name, level, keywords }) => {
          const tooltip = keywords && keywords.length > 0 ? keywords.join(", ") : undefined;
          return (
            <li title={tooltip}>
              <span class="skill-name">{name}</span>
              {level && <span class="skill-level" set:html={level} />}
            </li>
          );
        }
      )
    }
  </ul>
</Section>

<style>
  ul {
    display: inline-flex;
    gap: 8px;
    flex-wrap: wrap;
  }

  li {
    border-radius: 6px;
    background: var(--badge-bg);
    color: var(--badge-color);
    font-size: 0.8rem;
    font-weight: 500;
    padding: 0.2rem 0.6rem;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: all 0.2s ease;
    cursor: default;
    border: 1px solid transparent;
  }

  li:hover {
    background: var(--accent-glow);
    color: var(--accent-color);
    border-color: var(--accent-color);
  }

  .skill-name {
    font-weight: 600;
  }

  .skill-level {
    color: var(--text-muted);
    font-size: 0.75rem;
    letter-spacing: 0.05rem;
  }

  li:hover .skill-level {
    color: var(--accent-color);
  }
</style>
