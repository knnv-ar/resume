---
interface Props {
  title: string;
  lang?: string;
}

const { title, lang = "es" } = Astro.props;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Astro description" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/resume-es/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();
      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
<style is:global>
  :root {
    --bg-color: #ffffff;
    --text-color: #222222;
    --text-muted: #666666;
    --text-strong: #111111;
    --accent-color: #2563eb;
    --accent-glow: rgba(37, 99, 235, 0.1);
    --border-color: #eeeeee;
    --badge-bg: #f3f4f6;
    --badge-color: #374151;
    --kbd-bg: #e5e7eb;
    --kbd-color: #1f2937;
    --footer-bg: #fafafa;
    --card-bg: #ffffff;
    --card-shadow: 0 1px 3px rgba(0, 0, 0, 0.05);
    --card-hover-border: #d1d5db;
  }

  :root.dark {
    --bg-color: #121214;
    --text-color: #c9d1d9;
    --text-muted: #8b949e;
    --text-strong: #f0f6fc;
    --accent-color: #58a6ff;
    --accent-glow: rgba(88, 166, 255, 0.15);
    --border-color: #30363d;
    --badge-bg: #21262d;
    --badge-color: #c9d1d9;
    --kbd-bg: #21262d;
    --kbd-color: #c9d1d9;
    --footer-bg: #161b22;
    --card-bg: #161b22;
    --card-shadow: 0 4px 12px rgba(0, 0, 0, 0.25);
    --card-hover-border: #8b949e;
  }

  html {
    font-family:
      Menlo,
      Monaco,
      Lucida Console,
      "Courier New",
      Courier,
      monospace;
    background: var(--bg-color);
    color: var(--text-color);
    letter-spacing: -0.025rem;
    transition: background-color 0.3s ease, color 0.3s ease;
  }

  body,
  figure {
    margin: 0;
    padding: 0;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  h1,
  h2,
  h3,
  h4 {
    margin: 0;
    color: var(--text-strong);
    font-family:
      system-ui,
      -apple-system,
      BlinkMacSystemFont,
      "Segoe UI",
      Roboto,
      Oxygen,
      Ubuntu,
      Cantarell,
      "Open Sans",
      "Helvetica Neue",
      sans-serif;
  }

  p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.5;
    margin: 0;
    text-wrap: pretty;
  }

  @media print {
    :root, :root.dark {
      --bg-color: #ffffff !important;
      --text-color: #222222 !important;
      --text-muted: #666666 !important;
      --text-strong: #111111 !important;
      --border-color: #eeeeee !important;
      --badge-bg: #f3f4f6 !important;
      --badge-color: #374151 !important;
      --card-bg: #ffffff !important;
      --card-shadow: none !important;
      --card-hover-border: #eeeeee !important;
    }

    html {
      background: #ffffff !important;
      color: #222222 !important;
    }

    .no-print {
      display: none !important;
    }

    article, li, section {
      break-inside: avoid;
      page-break-inside: avoid;
    }
  }

  .print {
    display: none !important;
  }

  @media print {
    .print {
      display: block !important;
    }
  }
</style>
